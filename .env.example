# Mini SofaScore-like service environment variables
#
# Copy this file to `.env` and fill in real values if needed.
#
# Fixture mode remains the default. If token is not set, the app seeds from
# `fixtures/live_payload.json` and does not start football-data polling.

# Path to SQLite database file used by the app
SOFASCORE_DB_PATH=./data/sofascore.db

# Path to local fixture snapshot used in test/demo mode
SOFASCORE_FIXTURE_PATH=./fixtures/live_payload.json

# Enable auto-seed from fixture on startup when DB is empty
# Values: true / false / 1 / 0 / yes / no / on / off
SOFASCORE_AUTO_SEED=true

# Logging level for the application and poller
# Values: DEBUG / INFO / WARNING / ERROR / CRITICAL
SOFASCORE_LOG_LEVEL=DEBUG

# football-data.org API token
# Leave empty to keep fixture mode only
SOFASCORE_FOOTBALL_DATA_TOKEN=

# Base URL for football-data.org API
SOFASCORE_FOOTBALL_DATA_BASE_URL=https://api.football-data.org

# Comma-separated competition codes or IDs to poll
# Example: PL,SA,CL
SOFASCORE_FOOTBALL_DATA_COMPETITIONS=PL

# Poll interval for the background ingestion loop, in seconds
SOFASCORE_FOOTBALL_DATA_POLL_INTERVAL_SECONDS=30

# HTTP timeout for football-data.org requests, in seconds
SOFASCORE_FOOTBALL_DATA_TIMEOUT_SECONDS=10.0


